{
  "name": "playwright-js-pom",
  "version": "1.0.0",
  "scripts": {
    "test": "playwright test",
    "test:basiclogin": "playwright test tests/testautomation_site",
    "test:saucedemo": "cross-env ENV=TestURL02 playwright test tests/saucedemo_site",
    "allure:generate": "allure generate ./allure-results --clean",
    "allure:open": "allure open ./allure-report",
    "allure:report": "allure generate ./allure-results --clean && allure open ./allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.6.0",
    "cross-env": "^10.1.0"
  },
  "dependencies": {
    "winston": "^3.18.3"
  }
  
}